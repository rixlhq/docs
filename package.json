{
  "name": "rixl-docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "vp run clean && vp lint && vp build",
    "clean": "rm -rf dist",
    "dev": "vp dev",
    "start": "vp preview",
    "serve": "vpx serve@latest --no-port-switching dist/client -l tcp://127.0.0.1:4173",
    "serve:spa": "vpx serve@latest --no-port-switching -s dist/client -l tcp://127.0.0.1:4173",
    "lint": "vp lint --max-warnings=0 && fumadocs-mdx",
    "lint:links": "bun run ./scripts/lint.ts",
    "lint:fix": "vp lint --fix",
    "format": "vp fmt",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "@radix-ui/react-presence": "^1.1.7",
    "@rixl/videosdk-react": "^0.27.0",
    "@takumi-rs/image-response": "^2.0.2",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-start": "^1.168.27",
    "@tanstack/start-static-server-functions": "^1.167.18",
    "class-variance-authority": "^0.7.1",
    "fumadocs-core": "^16.11.2",
    "fumadocs-mdx": "^15.1.0",
    "fumadocs-openapi": "^11.1.1",
    "fumadocs-ui": "^16.11.2",
    "lucide-react": "^1.24.0",
    "lucide-static": "^1.24.0",
    "openapi-sampler": "^1.7.4",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shiki": "^4.3.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/devtools-vite": "^0.8.1",
    "@types/bun": "^1.3.14",
    "@types/mdx": "^2.0.14",
    "@types/node": "26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "next-validate-link": "^1.6.6",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4",
    "vite-plus": "0.2.4",
    "wrangler": "^4.110.0"
  },
  "overrides": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.14",
      "onFail": "download"
    }
  }
}

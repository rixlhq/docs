{
  "name": "rixl-docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "bun run clean && bun lint && vite build",
    "clean": "rm -rf dist",
    "dev": "vite dev",
    "start": "vite preview",
    "serve": "bunx serve@latest --no-port-switching dist/client -l tcp://127.0.0.1:4173",
    "serve:spa": "bunx serve@latest --no-port-switching -s dist/client -l tcp://127.0.0.1:4173",
    "lint": "oxlint --max-warnings=0 && fumadocs-mdx",
    "lint:links": "bun ./scripts/lint.ts",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "@radix-ui/react-presence": "^1.1.6",
    "@rixl/videosdk-react": "^0.27.0",
    "@takumi-rs/image-response": "^1.8.7",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-start": "^1.168.27",
    "@tanstack/start-static-server-functions": "^1.167.18",
    "class-variance-authority": "^0.7.1",
    "fumadocs-core": "^16.10.7",
    "fumadocs-mdx": "^15.0.13",
    "fumadocs-openapi": "^11.0.6",
    "fumadocs-ui": "^16.10.7",
    "lucide-react": "^1.23.0",
    "lucide-static": "^1.23.0",
    "openapi-sampler": "^1.7.4",
    "radix-ui": "^1.6.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shiki": "^4.3.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/devtools-vite": "^0.8.1",
    "@types/bun": "^1.3.14",
    "@types/mdx": "^2.0.14",
    "@types/node": "26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "next-validate-link": "^1.6.6",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "wrangler": "^4.107.0"
  },
  "overrides": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "packageManager": "bun@1.3.10"
}
